#!/usr/bin/env python3
from __future__ import annotations

import json
import math
import re
import sys
import time
from dataclasses import dataclass
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Dict, List, Optional, Tuple

import requests
from bs4 import BeautifulSoup


SEOUL = timezone(timedelta(hours=9))
ROOT = Path(__file__).resolve().parents[1]
DATA_DIR = ROOT / "data"
DEBUG_DIR = ROOT / "debug"

UNIVERSE_PATH = DATA_DIR / "universe_kr_top400.json"
OUTPUT_PATH = DATA_DIR / "latest_krx.json"

HEADERS = {
    "User-Agent": (
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) "
        "Chrome/124.0.0.0 Safari/537.36"
    ),
    "Accept-Language": "ko-KR,ko;q=0.9,en-US;q=0.8,en;q=0.7",
    "Referer": "https://finance.naver.com/",
}


# ---------- 공용 유틸 ----------

def now_seoul() -> datetime:
    return datetime.now(SEOUL)


def ensure_dirs() -> None:
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    DEBUG_DIR.mkdir(parents=True, exist_ok=True)


def read_text_with_fallback(raw: bytes) -> str:
    for enc in ("euc-kr", "cp949", "utf-8"):
        try:
            return raw.decode(enc)
        except Exception:
            pass
    return raw.decode("utf-8", errors="replace")


def save_debug_html(name: str, html_text: str) -> None:
    ensure_dirs()
    path = DEBUG_DIR / name
    path.write_text(html_text, encoding="utf-8")
    print(f"[DEBUG] saved html -> {path}")


def to_number(text: str) -> Optional[float]:
    if text is None:
        return None
    s = str(text).strip().replace(",", "").replace("%", "")
    s = s.replace("＋", "+").replace("－", "-")
    if not s or s in {"-", "--", "N/A"}:
        return None
    try:
        return float(s)
    except Exception:
        return None


def format_pct(pct: float) -> str:
    return f"{pct:+.1f}%".replace("+0.0%", "0.0%")


def format_eok(eok: float) -> str:
    if not math.isfinite(eok):
        return "--"
    if eok >= 10000:
        return f"{eok / 10000:.2f}조"
    if eok >= 100:
        return f"{round(eok):,}억"
    return f"{eok:.1f}억"


def yyyy_mm_dd(date_str: str) -> str:
    if len(date_str) == 8:
        return f"{date_str[:4]}-{date_str[4:6]}-{date_str[6:8]}"
    return date_str


def load_universe() -> List[dict]:
    with UNIVERSE_PATH.open("r", encoding="utf-8") as f:
        data = json.load(f)
    if not isinstance(data, list):
        raise ValueError("universe_kr_top400.json 형식이 리스트가 아닙니다.")
    return data


def market_suffix(code: str) -> str:
    # universe 파일에서 시장 정보가 없으므로 대략 코드 매칭 후, 코스닥 여부는 universe name 대신 후속 매핑에서 처리
    # 이 함수는 기본값만 제공하고 실제 suffix는 universe_map에서 override 가능
    return ".KS"


def load_existing_payload() -> Optional[dict]:
    if not OUTPUT_PATH.exists():
        return None
    try:
        return json.loads(OUTPUT_PATH.read_text(encoding="utf-8"))
    except Exception as e:
        print(f"[WARN] 기존 latest_krx.json 읽기 실패: {e}")
        return None


def save_payload(payload: dict) -> None:
    ensure_dirs()
    OUTPUT_PATH.write_text(
        json.dumps(payload, ensure_ascii=False, indent=2),
        encoding="utf-8",
    )
    print(f"[OK] saved -> {OUTPUT_PATH}")


def build_error_payload(message: str) -> dict:
    return {
        "generated_at": now_seoul().isoformat(),
        "trade_date": now_seoul().strftime("%Y%m%d"),
        "trade_date_display": yyyy_mm_dd(now_seoul().strftime("%Y%m%d")),
        "source": "Naver KRX+NXT table 기준",
        "universe_name": "KOSPI200 + KOSDAQ200 by market cap",
        "counts": {
            "universe": 0,
            "top_current_30": 0,
            "top_rise_30": 0,
            "leaders": 0,
        },
        "leaders": [],
        "by_symbol": {},
        "status": "error",
        "fallback_used": False,
        "message": message,
    }


# ---------- 거래대금 문자열 파싱 ----------

def parse_trade_value_to_eok(text: str) -> Optional[float]:
    """
    NAVER 표에 보이는 문자열을 '억원' 단위 float으로 환산.
    예:
      7.36조 -> 73600
      9470억 -> 9470
      3548억 -> 3548
      8500만 -> 0.85
      123백만 -> 1.23
      12,345 -> 12345 (이미 억 단위 숫자로 간주하지 않음; 일반 숫자는 None 처리)
    """
    if text is None:
        return None

    s = str(text).strip()
    s = s.replace(",", "").replace(" ", "")
    if not s or s in {"-", "--"}:
        return None

    # 숫자만 있으면 단위가 불명확하므로 보수적으로 None
    if re.fullmatch(r"[+-]?\d+(\.\d+)?", s):
        return None

    try:
        if "조" in s:
            m = re.search(r"([+-]?\d+(?:\.\d+)?)조", s)
            if m:
                return float(m.group(1)) * 10000
        if "억" in s:
            m = re.search(r"([+-]?\d+(?:\.\d+)?)억", s)
            if m:
                return float(m.group(1))
        if "만" in s:
            m = re.search(r"([+-]?\d+(?:\.\d+)?)만", s)
            if m:
                # 1억 = 10000만
                return float(m.group(1)) / 10000
        if "백만" in s:
            m = re.search(r"([+-]?\d+(?:\.\d+)?)백만", s)
            if m:
                # 1억 = 100백만
                return float(m.group(1)) / 100
    except Exception:
        return None

    return None


# ---------- NAVER 표 파싱 ----------

@dataclass
class ParsedRow:
    code: str
    name: str
    pct: float
    trade_value_eok: float
    market: str


def build_session() -> requests.Session:
    s = requests.Session()
    s.headers.update(HEADERS)
    return s


def fetch_html(session: requests.Session, method: str, url: str, *, data=None, params=None, debug_name: str = "") -> str:
    r = session.request(method, url, data=data, params=params, timeout=20)
    r.raise_for_status()
    text = read_text_with_fallback(r.content)
    if debug_name:
        save_debug_html(debug_name, text)
    return text


def extract_code_from_href(href: str) -> Optional[str]:
    if not href:
        return None
    m = re.search(r"code=(\d{6})", href)
    return m.group(1) if m else None


def find_header_indexes(table) -> Dict[str, int]:
    """
    헤더에서 종목명 / 등락률 / 거래대금 열 인덱스 추정.
    """
    header_map: Dict[str, int] = {}
    thead = table.find("thead")
    if not thead:
        return header_map

    header_texts: List[str] = []
    for th in thead.find_all("th"):
        txt = th.get_text(" ", strip=True).replace("\n", " ").strip()
        header_texts.append(txt)

    for idx, txt in enumerate(header_texts):
        compact = txt.replace(" ", "")
        if "종목명" in compact or compact == "종목명":
            header_map["name"] = idx
        elif "등락률" in compact:
            header_map["pct"] = idx
        elif "거래대금" in compact:
            header_map["amount"] = idx

    return header_map


def parse_market_sum_table(html_text: str, market_label: str) -> List[ParsedRow]:
    soup = BeautifulSoup(html_text, "lxml")
    tables = soup.select("table.type_2")
    if not tables:
        return []

    table = tables[0]
    header_idx = find_header_indexes(table)

    rows: List[ParsedRow] = []
    tbody = table.find("tbody")
    if not tbody:
        return rows

    for tr in tbody.find_all("tr"):
        tds = tr.find_all("td")
        if not tds:
            continue

        a = tr.select_one("a[href*='item/main.naver?code=']")
        if not a:
            continue

        code = extract_code_from_href(a.get("href", ""))
        name = a.get_text(strip=True)
        if not code or not name:
            continue

        # 헤더 인덱스가 있으면 우선 사용
        pct = None
        amount_eok = None

        if "pct" in header_idx and header_idx["pct"] < len(tds):
            pct = to_number(tds[header_idx["pct"]].get_text(strip=True))

        if "amount" in header_idx and header_idx["amount"] < len(tds):
            amount_eok = parse_trade_value_to_eok(tds[header_idx["amount"]].get_text(strip=True))

        # 헤더 탐지가 실패하면 보조 스캔
        if pct is None:
            for td in tds:
                txt = td.get_text(strip=True)
                if "%" in txt:
                    num = to_number(txt)
                    if num is not None:
                        pct = num
                        break

        if amount_eok is None:
            for td in reversed(tds):
                txt = td.get_text(strip=True)
                if any(unit in txt for unit in ("조", "억", "만", "백만")):
                    parsed = parse_trade_value_to_eok(txt)
                    if parsed is not None:
                        amount_eok = parsed
                        break

        if pct is None or amount_eok is None:
            continue

        rows.append(
            ParsedRow(
                code=code,
                name=name,
                pct=float(pct),
                trade_value_eok=float(amount_eok),
                market=market_label,
            )
        )

    return rows


def fetch_krx_market_pages(session: requests.Session, sosok: int, market_name: str, max_pages: int = 20) -> List[ParsedRow]:
    """
    KRX 표:
      https://finance.naver.com/sise/sise_market_sum.naver
      https://finance.naver.com/sise/sise_market_sum.naver?sosok=1
    """
    all_rows: List[ParsedRow] = []

    base_url = "https://finance.naver.com/sise/sise_market_sum.naver"
    params_base = {"sosok": sosok} if sosok else {}

    for page in range(1, max_pages + 1):
        params = dict(params_base)
        params["page"] = page
        html = fetch_html(
            session,
            "GET",
            base_url,
            params=params,
            debug_name=f"debug_krx_{market_name.lower()}_p{page}.html",
        )
        rows = parse_market_sum_table(html, market_name)
        print(f"[PARSE] KRX {market_name} page {page}: {len(rows)} rows")
        if not rows:
            break

        # 중복 방지
        before = len(all_rows)
        existing = {r.code for r in all_rows}
        for row in rows:
            if row.code not in existing:
                all_rows.append(row)
        if len(all_rows) == before:
            break

        time.sleep(0.2)

    return all_rows


def fetch_nxt_pages(session: requests.Session, sosok: int, market_name: str, max_pages: int = 20) -> List[ParsedRow]:
    """
    NXT 표:
      https://finance.naver.com/sise/nxt_sise_quant.naver
      https://finance.naver.com/sise/nxt_sise_quant.naver?sosok=1
    """
    all_rows: List[ParsedRow] = []

    base_url = "https://finance.naver.com/sise/nxt_sise_quant.naver"
    params_base = {"sosok": sosok} if sosok else {}

    for page in range(1, max_pages + 1):
        params = dict(params_base)
        params["page"] = page
        html = fetch_html(
            session,
            "GET",
            base_url,
            params=params,
            debug_name=f"debug_nxt_{market_name.lower()}_p{page}.html",
        )
        rows = parse_market_sum_table(html, market_name)
        print(f"[PARSE] NXT {market_name} page {page}: {len(rows)} rows")
        if not rows:
            break

        before = len(all_rows)
        existing = {r.code for r in all_rows}
        for row in rows:
            if row.code not in existing:
                all_rows.append(row)
        if len(all_rows) == before:
            break

        time.sleep(0.2)

    return all_rows


# ---------- 데이터 합산 / payload ----------

def build_universe_maps(universe: List[dict]) -> Tuple[Dict[str, dict], Dict[str, str]]:
    """
    universe_kr_top400.json은 최소 code/name/market 정도를 가진다고 가정.
    """
    by_code: Dict[str, dict] = {}
    suffix_map: Dict[str, str] = {}
    for item in universe:
        code = str(item.get("code", "")).zfill(6)
        if not code:
            continue
        by_code[code] = item
        market = str(item.get("market", "")).upper()
        if "KOSDAQ" in market or item.get("suffix") == ".KQ":
            suffix_map[code] = ".KQ"
        else:
            suffix_map[code] = ".KS"
    return by_code, suffix_map


def merge_rows(
    universe: List[dict],
    krx_kospi: List[ParsedRow],
    krx_kosdaq: List[ParsedRow],
    nxt_kospi: List[ParsedRow],
    nxt_kosdaq: List[ParsedRow],
) -> List[dict]:
    universe_map, suffix_map = build_universe_maps(universe)
    agg: Dict[str, dict] = {}

    def apply(rows: List[ParsedRow], source_tag: str) -> None:
        for row in rows:
            if row.code not in universe_map:
                continue

            if row.code not in agg:
                suffix = suffix_map.get(row.code, ".KS")
                agg[row.code] = {
                    "code": row.code,
                    "symbol": row.code + suffix,
                    "name": universe_map[row.code].get("name") or row.name,
                    "market": universe_map[row.code].get("market") or row.market,
                    "pct": row.pct,
                    "trade_value_eok": 0.0,
                    "sources": [],
                }

            # 장중엔 등락률은 KRX/NXT 어느 쪽이든 거의 같다고 보고, 가장 최근 적용값으로 갱신
            agg[row.code]["pct"] = row.pct
            agg[row.code]["trade_value_eok"] += row.trade_value_eok
            agg[row.code]["sources"].append(source_tag)

    apply(krx_kospi, "KRX_KOSPI")
    apply(krx_kosdaq, "KRX_KOSDAQ")
    apply(nxt_kospi, "NXT_KOSPI")
    apply(nxt_kosdaq, "NXT_KOSDAQ")

    merged: List[dict] = []
    for _, item in agg.items():
        pct = float(item["pct"])
        eok = float(item["trade_value_eok"])
        merged.append({
            "code": item["code"],
            "symbol": item["symbol"],
            "name": item["name"],
            "market": item["market"],
            "close": None,
            "pct": round(pct, 4),
            "pct_text": format_pct(pct),
            "trade_value_eok": round(eok, 4),
            "trade_value_text": format_eok(eok),
            "source_parts": item["sources"],
        })

    return merged


def build_payload(universe: List[dict], merged_rows: List[dict]) -> dict:
    amount_ranked = sorted(
        merged_rows,
        key=lambda x: (-float(x["trade_value_eok"]), -float(x["pct"]))
    )
    rise_ranked = sorted(
        merged_rows,
        key=lambda x: (-float(x["pct"]), -float(x["trade_value_eok"]))
    )

    top_c = {item["symbol"] for item in amount_ranked[:30]}
    top_e = {item["symbol"] for item in rise_ranked[:30]}
    leaders = [item for item in amount_ranked if item["symbol"] in top_c and item["symbol"] in top_e]
    by_symbol = {item["symbol"]: item for item in merged_rows}

    trade_date = now_seoul().strftime("%Y%m%d")

    return {
        "generated_at": now_seoul().isoformat(),
        "trade_date": trade_date,
        "trade_date_display": yyyy_mm_dd(trade_date),
        "source": "Naver KRX+NXT table 기준",
        "universe_name": "KOSPI200 + KOSDAQ200 by market cap",
        "counts": {
            "universe": len(merged_rows),
            "top_current_30": min(30, len(amount_ranked)),
            "top_rise_30": min(30, len(rise_ranked)),
            "leaders": len(leaders),
        },
        "leaders": leaders,
        "by_symbol": by_symbol,
        "status": "ok",
        "fallback_used": False,
        "message": "",
    }


# ---------- 메인 ----------

def main() -> None:
    ensure_dirs()

    try:
        universe = load_universe()
    except Exception as e:
        payload = build_error_payload(f"유니버스 로드 실패: {e}")
        save_payload(payload)
        sys.exit(1)

    session = build_session()

    try:
        krx_kospi = fetch_krx_market_pages(session, sosok=0, market_name="KOSPI")
        krx_kosdaq = fetch_krx_market_pages(session, sosok=1, market_name="KOSDAQ")
        nxt_kospi = fetch_nxt_pages(session, sosok=0, market_name="KOSPI")
        nxt_kosdaq = fetch_nxt_pages(session, sosok=1, market_name="KOSDAQ")

        print(f"[TOTAL] KRX KOSPI  rows: {len(krx_kospi)}")
        print(f"[TOTAL] KRX KOSDAQ rows: {len(krx_kosdaq)}")
        print(f"[TOTAL] NXT KOSPI  rows: {len(nxt_kospi)}")
        print(f"[TOTAL] NXT KOSDAQ rows: {len(nxt_kosdaq)}")

        merged = merge_rows(universe, krx_kospi, krx_kosdaq, nxt_kospi, nxt_kosdaq)
        print(f"[TOTAL] merged universe rows: {len(merged)}")

        if len(merged) == 0:
            payload = build_error_payload(
                "Naver KRX/NXT 표 파싱 결과가 0건입니다. debug/*.html 파일을 확인하세요."
            )
            save_payload(payload)
            sys.exit(2)

        payload = build_payload(universe, merged)
        save_payload(payload)

        print("[DONE] latest_krx.json 생성 완료")
        print(f"[DONE] universe={payload['counts']['universe']}, leaders={payload['counts']['leaders']}")

    except Exception as e:
        payload = build_error_payload(f"실행 실패: {e}")
        save_payload(payload)
        raise


if __name__ == "__main__":
    main()